vi.mock('../repository.js', () => ({
  usersRepository: {
    findById:  vi.fn(),
    update:    vi.fn(),
    softDelete: vi.fn(),
    /* ... */
  },
}));

describe('usersService.delete', () => {
  it('rejects when the requester is not an admin', async () => {
    await expect(usersService.delete('any', { id: 'x', roles: ['STUDENT'] }))
      .rejects.toBeInstanceOf(ForbiddenError);
  });

  it('rejects when an admin tries to delete themselves', async () => {
    await expect(usersService.delete('me', { id: 'me', roles: ['ADMIN'] }))
      .rejects.toBeInstanceOf(ConflictError);
  });
});
